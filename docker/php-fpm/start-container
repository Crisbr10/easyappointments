#!/bin/bash
set -e

echo "➜ Ignore Permission Changes"
# Solo si el bind-mount es un checkout de git. Si el codigo se copia
# a la imagen (pro variante), /var/www/html no es un git repo y
# `git config` falla -> con `set -e` aborta todo el start.
[[ -d /var/www/html/.git ]] && git config --global --add safe.directory /var/www/html && git config core.fileMode false || echo "  ↳ /var/www/html no es un git repo, saltando git config."

echo "➜ Set Correct Permissions"
chmod -R 777 storage

echo "➜ Install Composer Dependencies"
[[ -d vendor ]] || composer install --no-dev --optimize-autoloader

echo "➜ Install NPM Dependencies"
[[ -d node_modules ]] || npm install

echo "➜ Build Project Assets"
[[ -d assets/vendor ]] || npx gulp compile

# =============================================================================
# Templating de archivos de configuracion
# =============================================================================
# Easy!Appointments lee su config de archivos PHP (config.php, email.php),
# no de env vars. Este bloque genera esos archivos desde las variables
# de entorno pasadas por docker-compose.prod.yml ANTES de levantar php-fpm.
#
# Si en el futuro la app pasa a leer env vars nativamente, este bloque
# se puede eliminar.
# =============================================================================

echo "➜ Generate config.php from environment"

# Sanity check: si falta APP_ENCRYPTION_KEY, abortamos.
# Esto evita arrancar con un encryption key debil derivado del path.
if [[ -z "${APP_ENCRYPTION_KEY}" ]]; then
    echo "✖ APP_ENCRYPTION_KEY is required. Refusing to start."
    echo "  Set it in .env (generate with: openssl rand -base64 48)"
    exit 1
fi

if [[ -z "${MYSQL_PASSWORD}" ]] || [[ -z "${MYSQL_ROOT_PASSWORD}" ]]; then
    echo "✖ MYSQL_PASSWORD and MYSQL_ROOT_PASSWORD are required."
    echo "  Set them in .env (generate with: openssl rand -hex 24)"
    exit 1
fi

# Detectar si hay un config.php previo (en volumen o bind-mount) que NO fue
# generado por nosotros. En ese caso, lo respetamos (ya paso el wizard de
# instalacion de la app). Solo lo regeneramos si no existe.
#
# Heuristica: si APP_BASE_URL no esta vacia y el config.php no contiene el
# comentario "# Generated by start-container", lo dejamos como esta.
if [[ -f /var/www/html/config.php ]] && \
   ! grep -q "Generated by start-container" /var/www/html/config.php; then
    echo "  ↳ config.php existe y no fue generado por este script. Respetandolo."
    echo "    Para forzar regeneracion: rm /var/www/html/config.php y reiniciar."
else
    cat > /var/www/html/config.php <<EOF
<?php
// Generated by start-container - DO NOT EDIT MANUALLY
// Editar las variables en .env del proyecto y reiniciar el contenedor.
class Config
{
    // ---- General ----
    const BASE_URL    = '${APP_BASE_URL}';
    const LANGUAGE    = '${APP_LANGUAGE:-english}';
    const DEBUG_MODE  = ${APP_DEBUG_MODE:-false};

    // ---- Database ----
    const DB_HOST     = '${DB_HOST}';
    const DB_NAME     = '${DB_NAME:-${MYSQL_DATABASE:-easyappointments}}';
    const DB_USERNAME = '${DB_USERNAME:-${MYSQL_USER:-ea_user}}';
    const DB_PASSWORD = '${DB_PASSWORD:-${MYSQL_PASSWORD}}';

    // ---- Google Calendar (opcional, se sobreescribe desde la UI) ----
    // const GOOGLE_SYNC_FEATURE = false;
    // const GOOGLE_CLIENT_ID = '';
    // const GOOGLE_CLIENT_SECRET = '';
}

// Encryption key para sesiones/cookies. Si no esta definida, CodeIgniter
// usa un hash debil derivado del path de la app.
if (!defined('ENCRYPTION_KEY')) {
    define('ENCRYPTION_KEY', '${APP_ENCRYPTION_KEY}');
}

// IPs de proxies de confianza para X-Forwarded-For (separadas por coma).
// Vacio = la app ve la IP real del request (no la del proxy).
if (!defined('TRUSTED_PROXY_IPS') && '${APP_TRUSTED_PROXY_IPS}' !== '') {
    define('TRUSTED_PROXY_IPS', '${APP_TRUSTED_PROXY_IPS}');
}

// CORS para la API REST. Vacio = solo same-origin.
if (!defined('CORS_ALLOWED_ORIGINS') && '${APP_CORS_ALLOWED_ORIGINS}' !== '') {
    define('CORS_ALLOWED_ORIGINS', '${APP_CORS_ALLOWED_ORIGINS}');
}
EOF
    chmod 644 /var/www/html/config.php
    echo "  ↳ config.php generado."
fi


echo "➜ Generate email.php from environment"

if [[ -n "${SMTP_HOST}" ]]; then
    # SMTP configurado via env vars.
    cat > /var/www/html/application/config/email.php <<EOF
<?php defined('BASEPATH') or exit('No direct script access allowed');
// Generated by start-container

\$config['useragent']        = 'Easy!Appointments';
\$config['protocol']         = 'smtp';
\$config['mailtype']         = 'html';
\$config['smtp_debug']       = 0;
\$config['smtp_auth']        = true;
\$config['smtp_host']        = '${SMTP_HOST}';
\$config['smtp_user']        = '${SMTP_USER}';
\$config['smtp_pass']        = '${SMTP_PASS}';
\$config['smtp_crypto']      = '${SMTP_CRYPTO}';
\$config['smtp_port']        = ${SMTP_PORT:-587};
\$config['from_name']        = '${SMTP_FROM_NAME:-Clinica Dental Octavio}';
\$config['from_address']     = '${SMTP_FROM_ADDRESS}';
\$config['crlf']             = "\r\n";
\$config['newline']          = "\r\n";
EOF
    echo "  ↳ email.php configurado con SMTP (${SMTP_HOST}:${SMTP_PORT:-587})."
else
    # Sin SMTP_HOST: dejar email.php con defaults (protocol=mail via ssmtp).
    # Los emails fallaran silenciosamente. La app NO rompe.
    if [[ ! -f /var/www/html/application/config/email.php ]] || \
       grep -q "Generated by start-container" /var/www/html/application/config/email.php; then
        cat > /var/www/html/application/config/email.php <<'EOF'
<?php defined('BASEPATH') or exit('No direct script access allowed');
// Generated by start-container - SMTP no configurado, usando ssmtp local

$config['useragent']    = 'Easy!Appointments';
$config['protocol']     = 'mail';
$config['mailtype']     = 'html';
$config['charset']      = 'utf-8';
$config['crlf']         = "\r\n";
$config['newline']      = "\r\n";
EOF
        echo "  ↳ email.php en modo ssmtp local (emails no funcionaran sin relay)."
    fi
fi


echo "➜ Configure ssmtp (local mail relay)"

cat > /etc/ssmtp/ssmtp.conf <<EOF
# Generated by start-container
root=postmaster
hostname=${SSMTP_HOSTNAME:-appointments.clinicadentaloctavio.com}
mailhub=${SSMTP_MAILHUB:-mail:25}
UseTLS=${SSMTP_USE_TLS:-NO}
UseSTARTTLS=${SSMTP_USE_STARTTLS:-NO}
AuthUser=${SSMTP_AUTH_USER}
AuthPass=${SSMTP_AUTH_PASS}
FromLineOverride=YES
EOF
echo "  ↳ ssmtp.conf -> mailhub=${SSMTP_MAILHUB:-mail:25}"


echo "➜ Listen To Incoming Requests"
exec php-fpm
