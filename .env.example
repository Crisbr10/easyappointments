# =============================================================================
# Easy!Appointments - Variables de Entorno (PRODUCCION)
# =============================================================================
# COPIA este archivo a `.env` y completa los secretos:
#   cp .env.example .env
#   chmod 600 .env
#   # editar .env y reemplazar todos los CHANGE_ME_*
#
# Generar secretos fuertes:
#   openssl rand -hex 24    # para passwords
#   openssl rand -base64 48 # para APP_ENCRYPTION_KEY
# =============================================================================


# -----------------------------------------------------------------------------
# Identidad publica
# -----------------------------------------------------------------------------
# URL por la que se accede a la app. CRITICO: debe coincidir con el dominio
# configurado en nginx_proxy_manager (Proxy Host -> Domain Names).
# Sin trailing slash.
APP_BASE_URL=https://appointments.clinicadentaloctavio.com
APP_LANGUAGE=spanish
APP_DEBUG_MODE=false
APP_ENV=production
SSMTP_HOSTNAME=appointments.clinicadentaloctavio.com


# -----------------------------------------------------------------------------
# Base de datos (MySQL 8.0)
# -----------------------------------------------------------------------------
# Estos valores se inyectan en config.php del contenedor php-fpm.
# DB_HOST debe ser el nombre del servicio en docker-compose.prod.yml
# (no localhost, no 127.0.0.1, no una IP).
DB_HOST=mysql
DB_PORT=3306

# Nombre de la BD y credenciales del usuario de la app (NO el root).
# IMPORTANTE: deben coincidir con MYSQL_DATABASE / MYSQL_USER / MYSQL_PASSWORD
# que se pasan al servicio mysql.
MYSQL_DATABASE=easyappointments
MYSQL_USER=ea_user
# Generar con: openssl rand -hex 24
MYSQL_PASSWORD=CHANGE_ME_mysql_user_password_24_bytes_hex

# Root password del MySQL. Solo se usa para admin manual via docker exec.
# CAMBIARLO y guardarlo en un lugar seguro (1Password, Bitwarden, etc).
# Generar con: openssl rand -hex 32
MYSQL_ROOT_PASSWORD=CHANGE_ME_mysql_root_password_32_bytes_hex


# -----------------------------------------------------------------------------
# Seguridad
# -----------------------------------------------------------------------------
# Encryption key usada por CodeIgniter para encriptar cookies de sesion.
# Sin esto, la app usa un hash derivado de paths del server (debil).
# Generar con: openssl rand -base64 48
APP_ENCRYPTION_KEY=CHANGE_ME_encryption_key_base64_48_bytes

# IPs de proxies de confianza (separadas por coma). VACIO por defecto.
# Cuando un request pasa por nginx_proxy_manager, la app ve la IP del proxy
# en $_SERVER['REMOTE_ADDR'] a menos que le digas que confíe en el proxy.
#
# Para obtener la IP de nginx_proxy_manager en easyappointments_public:
#   docker network inspect easyappointments_public \
#     --format '{{range .Containers}}{{.Name}}={{.IPv4Address}} {{end}}'
# (despues de attachear nginx_proxy_manager a esa red).
# Ejemplo: APP_TRUSTED_PROXY_IPS=172.25.0.2
APP_TRUSTED_PROXY_IPS=

# Origins CORS permitidos (separados por coma). VACIO = no CORS.
# Si n8n va a consumir la API desde otro dominio, agregalo aca.
# Ejemplo: https://n8n.clinicadentaloctavio.com
APP_CORS_ALLOWED_ORIGINS=


# -----------------------------------------------------------------------------
# SMTP para emails transaccionales (Resend, SendGrid, Mailgun, SES, etc)
# -----------------------------------------------------------------------------
# Si TODAS estas variables quedan vacias, email.php usa protocol=mail
# (ssmtp local) y los emails fallaran silenciosamente. La app NO rompe.
# Configurar cuando se quiera habilitar notificaciones reales.

# Proveedor SMTP. Ejemplos:
#   Resend:    smtp.resend.com
#   SendGrid:  smtp.sendgrid.net
#   Mailgun:   smtp.mailgun.org
#   Amazon SES: email-smtp.us-east-1.amazonaws.com
#   Gmail:     smtp.gmail.com (no recomendado para produccion)
SMTP_HOST=

# Puerto SMTP. Comunes: 587 (STARTTLS), 465 (SSL), 25 (sin TLS, raro).
SMTP_PORT=587

# Usuario SMTP (normalmente una API key del proveedor).
SMTP_USER=

# Password SMTP (la API key o password del usuario SMTP).
SMTP_PASS=

# Cifrado: tls (recomendado, puerto 587) o ssl (puerto 465).
# Si SMTP_PORT=25 sin TLS, dejar vacio.
SMTP_CRYPTO=tls

# Remitente que aparecera en los emails enviados.
SMTP_FROM_NAME=Clinica Dental Octavio
SMTP_FROM_ADDRESS=


# -----------------------------------------------------------------------------
# ssmtp (relay local, fallback si SMTP_HOST esta vacio)
# -----------------------------------------------------------------------------
# ssmtp se configura dentro del contenedor para que PHP use mail() via ssmtp.
# Solo se usa si no se configuro SMTP_HOST. Si tenes un relay local en la red
# easyappointments_core (ej: un contenedor 'mail'), apuntalo aca.
SSMTP_MAILHUB=mail:25
SSMTP_USE_TLS=NO
SSMTP_USE_STARTTLS=NO
SSMTP_AUTH_USER=
SSMTP_AUTH_PASS=
